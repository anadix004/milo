# ================================
# MILO Platform — Environment Setup
# ================================
# Copy this file to .env.local and fill in your Supabase credentials.

# Your Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared password for team accounts created via admin whitelist
TEAM_SHARED_PASSWORD=milo_team_2026
